#!/usr/bin/make -f

export CARGO_HOME = $(CURDIR)/debian/cargo-home
# Pin the target dir so a CARGO_TARGET_DIR from the environment cannot move
# the binary away from the path the install step expects.
export CARGO_TARGET_DIR = $(CURDIR)/target

# When a vendor/ directory is present (offline/air-gapped builds), configure
# Cargo to use it exclusively.  The vendor/ tree is generated by running
# `cargo vendor vendor` at the repository root and including the output in
# the source tarball.
ifneq ($(wildcard vendor/),)
export CARGO_NET_OFFLINE = true
export CARGO_UNSTABLE_OFFLINE = true
CARGO_FLAGS = --frozen --offline
endif

%:
	dh $@

override_dh_auto_build:
ifneq ($(wildcard vendor/),)
	$(if $(wildcard .cargo/config.toml),,$(MAKE) -f debian/rules debian/cargo-config)
endif
	cargo build --release --locked $(CARGO_FLAGS)

override_dh_auto_test:
	cargo test --release --locked $(CARGO_FLAGS)

override_dh_auto_install:
	install -D -m 0755 target/release/podup debian/podup/usr/bin/podup
	# Shell completions, generated from the freshly built binary so they can
	# never drift from the CLI definition.
	install -d debian/podup/usr/share/bash-completion/completions
	install -d debian/podup/usr/share/zsh/vendor-completions
	install -d debian/podup/usr/share/fish/vendor_completions.d
	target/release/podup completions bash > debian/podup/usr/share/bash-completion/completions/podup
	target/release/podup completions zsh  > debian/podup/usr/share/zsh/vendor-completions/_podup
	target/release/podup completions fish > debian/podup/usr/share/fish/vendor_completions.d/podup.fish

override_dh_auto_clean:
	cargo clean
	rm -rf debian/cargo-home

# Generate .cargo/config.toml pointing at the vendor tree (only when vendored).
debian/cargo-config:
ifneq ($(wildcard vendor/),)
	mkdir -p .cargo
	printf '[source.crates-io]\nreplace-with = "vendored-sources"\n\n[source.vendored-sources]\ndirectory = "vendor"\n' > .cargo/config.toml
endif
